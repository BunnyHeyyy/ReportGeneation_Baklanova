<UserControl x:Class="ReportGeneration_Baklanova.Items.Student"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ReportGeneration_Baklanova.Items"
             mc:Ignorable="d" >
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="100"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Image Width="80" Height="80" Margin="10" VerticalAlignment="Top" Source="/Images/ic_student.png"/>
        <TextBox x:Name="TBFio"  VerticalAlignment="Top" Height="25" Grid.Column="1" Margin="10, 10, 10,0" VerticalContentAlignment="Center" IsEnabled="False"/>
        <TextBox VerticalAlignment="Top" Height="25" Grid.Column="2" Margin="10, 10, 10,0" VerticalContentAlignment="Center" IsEnabled="False"/>
        <CheckBox x:Name="CBExpelled" Content="Отчислен" VerticalAlignment="Top" Grid.Column="1" Margin="10,40,240,0" IsEnabled="False"/>
        <Label Content="Выполненные работы: " VerticalAlignment="Top" Grid.Column="1" Margin="10,74,164,0"/>
        <ProgressBar x:Name="doneWorks" Height="25" Grid.Column="1" Margin="10,104,13,0" Grid.ColumnSpan="2" VerticalAlignment="Top"/>
        <Label Content="Посещаемость: " VerticalAlignment="Top" Grid.Column="1" Margin="10,135,164,0"/>
        <ProgressBar x:Name="missedCount" Height="25" Grid.Column="1" Margin="10,166,13,0" Grid.ColumnSpan="2" VerticalAlignment="Top"/>
    </Grid>
</UserControl>
