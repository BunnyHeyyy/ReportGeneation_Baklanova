<Page x:Class="ReportGeneration_Baklanova.Pages.Main"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ReportGeneration_Baklanova.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Main" >

    <Grid Background="Gainsboro">
        <Grid Margin="20" Background="White">
            <Grid Height="65" VerticalAlignment="Top">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <Label Content="Выберите группу: " VerticalAlignment="Top" Margin="5"/>
                <ComboBox x:Name="CBGroup" SelectionChanged="SelectGroup" Height="25" VerticalAlignment="Top" Margin="5,30,5,0"/>
                <Label Content="Фамилия и имя студента: " VerticalAlignment="Top" Margin="5,5,5,0" Grid.Column="1"/>
                <TextBox x:Name="TBFIO" KeyUp="SelectStudent" Height="25" VerticalAlignment="Top" Margin="5,30,5,0" Grid.Column="1"/>
            </Grid>
            <ScrollViewer Margin="0, 65, 0, 40">
                <StackPanel x:Name="Parent">
                    
                </StackPanel>
            </ScrollViewer>
            <Button Height="25" VerticalAlignment="Bottom" HorizontalAlignment="Right" Width="100" Content="Отчет" Margin="10"/>
        </Grid>
        
    </Grid>
</Page>
